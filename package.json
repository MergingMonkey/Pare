{
  "name": "pare",
  "version": "0.0.0",
  "private": true,
  "description": "Dev tools, optimized for agents. ~85% fewer tokens, 100% structured output.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dave-London/Pare.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "canary": "changeset version --snapshot canary",
    "changelog": "tsx scripts/aggregate-changelog.ts",
    "smoke": "vitest run --config tests/smoke/vitest.config.ts",
    "smoke:coverage": "tsx scripts/smoke-coverage.ts",
    "benchmark": "tsx benchmarks/v2/scripts/benchmark.ts",
    "benchmark:overhead": "tsx scripts/overhead-benchmark.ts",
    "docs:api": "typedoc",
    "sync-tool-counts": "tsx scripts/sync-tool-counts.ts",
    "sync-tool-counts:check": "tsx scripts/sync-tool-counts.ts --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.15",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.2",
      "express-rate-limit": ">=8.2.2"
    }
  }
}
